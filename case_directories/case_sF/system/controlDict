FoamFile
{
    version	2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     simpleFoam;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime		      831;

deltaT          1;

writeControl    timeStep;

writeInterval   830;

purgeWrite      0;

writeFormat     binary;

writePrecision  8;

writeCompression off;

timeFormat      general;

timePrecision   8;

runTimeModifiable yes;

libs (
	"libatmosphericModels.so"
	"libUserturbulenceModels.so"
      );

functions
{
  #includeFunc residuals
  #includeFunc probes
}

