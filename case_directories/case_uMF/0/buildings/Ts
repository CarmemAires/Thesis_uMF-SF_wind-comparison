FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "46800/buildings";
    object      Ts;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 305.21;

boundaryField
{
    sides
    {
        type            zeroGradient;
    }
    buildings_to_air
    {
        type            compressible::CFDHAMsolidTemperatureCoupledMixed;
        qrNbr           qr;
        qsNbr           qs;
        value           uniform 305.21;
    }
    interior
    {
        type            externalWallHeatFluxTemperature;
        mode            coefficient;
        kappaMethod     lookup;
        kappa           lambda_m;
        alphaAni        Anialpha;
        h               uniform 0.405;
        Ta              uniform 293.15;
        qr              none;
        refValue        uniform 305.21;
        refGradient     uniform 0;
        valueFraction   uniform 1;
        value           uniform 305.21;
    }
}


