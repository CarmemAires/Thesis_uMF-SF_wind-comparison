FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0/air";
    object      epsilon;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -3 0 0 0 0];

#include        "include/ABLConditions"

internalField   uniform $epsilonInlet;

boundaryField
{
    #include        "include/ABLConditions"

    inlet
    {
        type            atmBoundaryLayerInletEpsilon;
        #include        "include/ABLConditions"
        flowDir         $flowDir;
        zDir            $zDir;
        Zref            $Zref;
        Uref            $Uref;
        zGround         $zGround;
        z0              $z0;
        d               uniform 0.0;
        value           $internalField;
        // #include "$FOAM_CASE/0/air/include/epsilon_bc_air"
        // value            $epsilonInlet;

    }
    outlet
    {
        type            zeroGradient;

    }
    top
    {
        type            slip;
    }
    terrain
    {
        type            epsilonz0WallFunction;
        z0              $z0;
        value           $internalField;
    }
    vegetation
    {
        type            epsilonz0WallFunction;
        z0              $z0;
        value           $internalField;
    }
    side1
    {
        type            slip;
    }
    side2
    {
        type            slip;
    }
    buildings
    {
        type            epsilonWallFunction;
        value           uniform $epsilonInlet;
    }
}


